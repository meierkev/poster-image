{
    "name": "b13/poster-image",
    "description": "Poster Image - Sometimes you just need a poster image (for videos) ... in TYPO3",
    "type": "typo3-cms-extension",
    "license": [
        "GPL-2.0-or-later"
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.0 || ^14.0",
        "typo3/cms-filemetadata": "^13.0 || ^14.0"
    },
    "autoload": {
        "psr-4": {
            "B13\\PosterImage\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "poster_image",
            "version": "2.0.0",
            "Package": {
                "providesPackages": {}
            }
        }
    }
}
